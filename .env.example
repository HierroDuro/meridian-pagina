# ─────────────────────────────────────────────────────────────
# Copiá este archivo a ".env" y completá los valores reales.
# NUNCA subas el archivo ".env" a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Postgres (desarrollo y producción usan el mismo motor — ver
# prisma/schema.prisma). En Vercel se configura como variable de entorno
# del proyecto, no acá. Para desarrollo local, apuntá a tu propia base
# (por ejemplo, la misma instancia de Neon/Supabase que uses en Vercel).
DATABASE_URL="postgresql://usuario:password@host:puerto/base_de_datos"

# Secreto usado por NextAuth (Auth.js v5) para firmar JWT y cookies de sesión.
# Generalo con: openssl rand -base64 32
# Se define con los dos nombres (AUTH_SECRET y NEXTAUTH_SECRET, mismo valor)
# porque Auth.js v5 acepta ambos según la versión exacta del paquete.
AUTH_SECRET="reemplazar-con-un-secreto-aleatorio-de-al-menos-32-caracteres"
NEXTAUTH_SECRET="reemplazar-con-un-secreto-aleatorio-de-al-menos-32-caracteres"

# URL pública del sitio (usada por metadata/SEO).
# NEXTAUTH_URL NO se define a propósito: NextAuth (trustHost: true en
# auth.config.ts) detecta el host real de cada pedido automáticamente. Si se
# fija NEXTAUTH_URL a un valor fijo, todas las redirecciones de login usan
# ESE host sin importar desde dónde entrás — rompe el acceso a /admin desde
# cualquier dispositivo que no sea "localhost" (ej: el celular en la LAN).
NEXT_PUBLIC_APP_DOMAIN="localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Usuario administrador inicial (solo se usa una vez, al correr
# "npm run db:seed"). La contraseña se hashea con bcrypt antes
# de guardarse: nunca queda en texto plano en la base de datos
# ni en el código fuente.
# ─────────────────────────────────────────────────────────────
ADMIN_USERNAME="Fito"
ADMIN_PASSWORD="cambiar-esta-contrasena-antes-de-seedear"
