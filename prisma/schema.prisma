// ─────────────────────────────────────────────────────────────
// Prisma schema — B2B Ecommerce
// Usar Prisma Client (con consultas parametrizadas) es en sí
// mismo la principal defensa contra SQL Injection: nunca se
// concatenan strings SQL a mano en este proyecto.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Categoría de productos (Tecnología, Resmas, Gráfica, ...).
model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("categories")
}

/// Producto del catálogo B2B.
model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String   @db.Text
  brand       String
  price       Decimal  @db.Decimal(12, 2)
  stock       Int      @default(0)
  imageUrl    String
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  isOnSale    Boolean  @default(false)
  salePrice   Decimal? @db.Decimal(12, 2)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Frequently filtered/sorted columns get indexes so the catalog
  // stays fast as the number of products grows.
  @@index([categoryId])
  @@index([isFeatured])
  @@index([isActive])
  @@index([brand])
  @@index([createdAt])
  @@map("products")
}

/// Rol de un usuario administrador. Se modela como enum para poder
/// extender a roles adicionales (por ejemplo "editor") sin romper el schema.
enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

/// Usuario con acceso al panel /admin. Solo se guarda el hash bcrypt
/// de la contraseña, nunca el valor en texto plano.
model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(SUPER_ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

/// Configuración global del sitio (nombre, logo, moneda, etc.),
/// editable desde el panel de administración.
model SiteConfig {
  id          String   @id @default(cuid())
  siteName    String   @default("Meridian B2B")
  currency    String   @default("ARS")
  contactMail String?
  updatedAt   DateTime @updatedAt

  @@map("site_config")
}
